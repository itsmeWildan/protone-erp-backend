APP_NAME=ProtoERP
APP_ENV=local
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=protone_erp
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# Migration
MIGRATION_PATH=file://internal/infrastructure/persistence/migrations
